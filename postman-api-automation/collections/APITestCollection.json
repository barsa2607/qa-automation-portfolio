{
  "info": {
    "name": "ReqRes API Automation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET All Users",
      "request": {
        "method": "GET",
        "url": "https://reqres.in/api/users?page=1"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
            "pm.test('Response has data array', function() { pm.expect(pm.response.json()).to.have.property('data'); });",
            "pm.environment.set('userId', pm.response.json().data[0].id);"
          ]
        }
      }]
    },
    {
      "name": "GET Single User",
      "request": {
        "method": "GET",
        "url": "https://reqres.in/api/users/{{userId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
            "pm.test('User has valid email', function() { pm.expect(pm.response.json().data.email).to.include('@'); });"
          ]
        }
      }]
    },
    {
      "name": "POST Create User",
      "request": {
        "method": "POST",
        "url": "https://reqres.in/api/users",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Barsa Sahu\", \"job\": \"QA Automation Engineer\"}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 201', function() { pm.response.to.have.status(201); });",
            "pm.test('User created with correct name', function() { pm.expect(pm.response.json().name).to.eql('Barsa Sahu'); });",
            "pm.environment.set('createdUserId', pm.response.json().id);"
          ]
        }
      }]
    },
    {
      "name": "PUT Update User",
      "request": {
        "method": "PUT",
        "url": "https://reqres.in/api/users/{{createdUserId}}",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Barsa Sahu\", \"job\": \"Senior QA Automation Engineer\"}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
            "pm.test('Job title updated', function() { pm.expect(pm.response.json().job).to.eql('Senior QA Automation Engineer'); });"
          ]
        }
      }]
    },
    {
      "name": "DELETE User",
      "request": {
        "method": "DELETE",
        "url": "https://reqres.in/api/users/{{createdUserId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 204', function() { pm.response.to.have.status(204); });"
          ]
        }
      }]
    },
    {
      "name": "GET Invalid User - Negative Test",
      "request": {
        "method": "GET",
        "url": "https://reqres.in/api/users/9999"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 404', function() { pm.response.to.have.status(404); });"
          ]
        }
      }]
    }
  ]
}
