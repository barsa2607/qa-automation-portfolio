{
  "info": {
    "name": "ReqRes API Automation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET All Users",
      "request": {
        "method": "GET",
        "url": "https://reqres.in/api/users?page=1"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
            "pm.test('Response has data array', function() { pm.expect(pm.response.json()).to.have.property('data'); });",
            "pm.test('Data array is not empty', function() { pm.expect(pm.response.json().data.length).to.be.above(0); });",
            "pm.environment.set('userId', pm.response.json().data[0].id);"
          ]
        }
      }]
    },
    {
      "name": "GET Single User",
      "request": {
        "method": "GET",
        "url": "https://reqres.in/api/users/2"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
            "pm.test('User has email', function() { pm.expect(pm.response.json().data).to.have.property('email'); });",
            "pm.test('User id is 2', function() { pm.expect(pm.response.json().data.id).to.eql(2); });"
          ]
        }
      }]
    },
    {
      "name": "GET Second Page Users",
      "request": {
        "method": "GET",
        "url": "https://reqres.in/api/users?page=2"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
            "pm.test('Page number is 2', function() { pm.expect(pm.response.json().page).to.eql(2); });",
            "pm.test('Has total count', function() { pm.expect(pm.response.json()).to.have.property('total'); });"
          ]
        }
      }]
    },
    {
      "name": "POST Create User",
      "request": {
        "method": "POST",
        "url": "https://reqres.in/api/users",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Barsa Sahu\", \"job\": \"QA Automation Engineer\"}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 201', function() { pm.response.to.have.status(201); });",
            "pm.test('User created with correct name', function() { pm.expect(pm.response.json().name).to.eql('Barsa Sahu'); });",
            "pm.test('Response has id', function() { pm.expect(pm.response.json()).to.have.property('id'); });",
            "pm.test('Response has createdAt', function() { pm.expect(pm.response.json()).to.have.property('createdAt'); });"
          ]
        }
      }]
    },
    {
      "name": "GET User Not Found - Negative Test",
      "request": {
        "method": "GET",
        "url": "https://reqres.in/api/users/9999"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 404', function() { pm.response.to.have.status(404); });",
            "pm.test('Response body is empty', function() { pm.expect(pm.response.text()).to.include('{}'); });"
          ]
        }
      }]
    },
    {
      "name": "POST Login Successful",
      "request": {
        "method": "POST",
        "url": "https://reqres.in/api/login",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"eve.holt@reqres.in\", \"password\": \"cityslicka\"}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
            "pm.test('Response has token', function() { pm.expect(pm.response.json()).to.have.property('token'); });"
          ]
        }
      }]
    },
    {
      "name": "POST Login Failed - Negative Test",
      "request": {
        "method": "POST",
        "url": "https://reqres.in/api/login",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"invalid@test.com\"}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status code is 400', function() { pm.response.to.have.status(400); });",
            "pm.test('Error message present', function() { pm.expect(pm.response.json()).to.have.property('error'); });"
          ]
        }
      }]
    }
  ]
}
